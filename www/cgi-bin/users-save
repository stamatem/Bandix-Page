#!/bin/busybox sh

echo "" > /tmp/bandix.log
echo "RUN $(date)" >> /tmp/bandix.log

# 🔒 ATOMIC LOCK
LOCK="/tmp/bandix.lock"

# remove stale lock
if [ -d "$LOCK" ]; then
    AGE=$(( $(date +%s) - $(stat -c %Y "$LOCK" 2>/dev/null || echo 0) ))
    if [ "$AGE" -gt 30 ]; then
        echo "[Bandix] REMOVE STALE LOCK" >> /tmp/bandix.log
        rm -rf "$LOCK"
    fi
fi

if ! mkdir "$LOCK" 2>/dev/null; then
    echo "[Bandix] LOCKED" >> /tmp/bandix.log
    exit 0
fi

cleanup() {
    rm -rf "$LOCK"
}
trap cleanup EXIT INT TERM

DATA_FILE="/www/data/users.json"
PAY_FILE="/www/data/users-pay.json"

# 🔐 load password from users-pay.json
if [ -f "$PAY_FILE" ]; then
    PASSWORD=$(jsonfilter -i "$PAY_FILE" -e '@.password')
else
    PASSWORD=""
fi

TMP_FILE="/tmp/users.json.tmp"
MAX_SIZE=65536

read_post_data() {
    if [ -n "$CONTENT_LENGTH" ]; then
        read -r -n "$CONTENT_LENGTH" POST_DATA
    else
        POST_DATA=$(cat)
    fi
}

respond() {
    echo "Content-Type: application/json"
    echo ""
    echo "$1"
}

generate_users_ordered() {

    FILE="$1"

    jsonfilter -i "$FILE" -e '@' | \
    tr '{},' '\n' | grep ':' | cut -d':' -f1 | tr -d '" ' | \
    while read -r USER; do

        # skip system keys
        echo "$USER" | grep -q "^_" && continue

        # skip numeric keys (THIS is your missing filter)
        echo "$USER" | grep -Eq '^[0-9]+$' && continue

        # must have macs array
        TEST=$(jsonfilter -i "$FILE" -e "@.$USER.macs[0]" 2>/dev/null)
        [ -z "$TEST" ] && continue

        echo "$USER"
    done
}

generate_users_fingerprint() {

    FILE="$1"

    generate_users_ordered "$FILE" | while read -r USER; do
        MACS=$(jsonfilter -i "$FILE" -e "@.$USER.macs[*]" 2>/dev/null)
        echo "$USER:$MACS"
    done | sort | md5sum | cut -d' ' -f1
}

# 🔥 DHCP FUNCTION
add_dhcp_leases() {

    INDEX=0
    while true; do
        NAME=$(uci get dhcp.@host[$INDEX].name 2>/dev/null)
        [ -z "$NAME" ] && break

        TAG=$(uci get dhcp.@host[$INDEX].tag 2>/dev/null)

        if [ "$TAG" = "bandix" ]; then
            uci delete dhcp.@host[$INDEX]
            continue
        fi

        INDEX=$((INDEX + 1))
    done

    USER_INDEX=0

    USERS=$(generate_users_ordered "$DATA_FILE")

    for USER in $USERS; do

        BASE=$((20 + USER_INDEX * 10))
        MAC_INDEX=0

        while true; do

            MAC=$(jsonfilter -i "$DATA_FILE" -e "@.$USER.macs[$MAC_INDEX]" 2>/dev/null)
            [ -z "$MAC" ] && break

            MAC_UP=$(echo "$MAC" | tr '[:lower:]' '[:upper:]')
            NETWORK=$(jsonfilter -i "$DATA_FILE" -e '@._network' 2>/dev/null)

            # fallback if missing
            [ -z "$NETWORK" ] && NETWORK="192.168.2"

            # ✅ ADD THIS LINE (3-octet protection)
            echo "$NETWORK" | grep -Eq '^([0-9]{1,3}\.){2}[0-9]{1,3}$' || NETWORK="192.168.2"

            IP="$NETWORK.$((BASE + MAC_INDEX))"
            NAME="${USER}-$((MAC_INDEX + 1))"

            SECTION=$(uci add dhcp host)

            uci set dhcp.$SECTION.name="$NAME"
            uci add_list dhcp.$SECTION.mac="$MAC_UP"
            uci set dhcp.$SECTION.ip="$IP"
            uci set dhcp.$SECTION.leasetime='infinite'
            uci set dhcp.$SECTION.tag='bandix'

            MAC_INDEX=$((MAC_INDEX + 1))
        done

        [ "$MAC_INDEX" -gt 0 ] && USER_INDEX=$((USER_INDEX + 1))
    done

    uci commit dhcp || return 1

    ubus call service reload '{"name":"dnsmasq"}' 2>/dev/null \
        || /etc/init.d/dnsmasq restart \
        || return 1

    return 0
}

update_cron() {

    REFRESH=$(jsonfilter -i "$DATA_FILE" -e '@._refresh' 2>/dev/null)
    [ -z "$REFRESH" ] && REFRESH=2
    [ "$REFRESH" -lt 1 ] && REFRESH=1
    [ "$REFRESH" -gt 60 ] && REFRESH=60

    # remove old bandix cron
    sed -i '/bandix-cron/d' /etc/crontabs/root

    # add new one
    echo "*/$REFRESH * * * * /usr/bin/bandix-flush && /usr/bin/bandix-quota # bandix-cron" >> /etc/crontabs/root

    # reload cron
    /etc/init.d/cron restart
}
# -------------------------

read_post_data

# 🧹 CLEANUP ACTION (before normal validation flow)
ACTION=$(echo "$POST_DATA" | jsonfilter -e '@.action')

if [ "$ACTION" = "cleanup" ]; then

    PASS=$(echo "$POST_DATA" | jsonfilter -e '@.password')

    [ "$PASS" = "$PASSWORD" ] || {
        respond '{"status":"error","message":"unauthorized"}'
        exit 1
    }

    echo "[Bandix] CLEANUP TRIGGERED" >> /tmp/bandix.log

    rm -rf /usr/share/bandix/* 2>> /tmp/bandix.log

    /etc/init.d/bandix restart >> /tmp/bandix.log 2>&1 || {
        echo "[Bandix] restart failed" >> /tmp/bandix.log
        respond '{"status":"error","message":"restart_failed"}'
        exit 1
    }

    # ⏱️ delayed flush in background (non-blocking)
    (
        sleep 10
        /usr/bin/bandix-flush >> /tmp/bandix.log 2>&1 || {
            echo "[Bandix] flush failed" >> /tmp/bandix.log
        }
    ) &

    respond '{"status":"ok"}'
    exit 0
fi

[ -n "$POST_DATA" ] || {
    respond '{"status":"error","message":"empty"}'
    exit 1
}

SIZE=$(printf "%s" "$POST_DATA" | wc -c)
[ "$SIZE" -le "$MAX_SIZE" ] || {
    respond '{"status":"error","message":"too_large"}'
    exit 1
}

PASS=$(echo "$POST_DATA" | jsonfilter -e '@.password')

[ "$PASS" = "$PASSWORD" ] || {
    respond '{"status":"error","message":"unauthorized"}'
    exit 1
}

DATA=$(echo "$POST_DATA" | jsonfilter -e '@.data')

[ -n "$DATA" ] || {
    respond '{"status":"error","message":"no_data"}'
    exit 1
}

echo "$DATA" | jsonfilter -e '@' >/dev/null 2>&1 || {
    respond '{"status":"error","message":"invalid_json"}'
    exit 1
}

mkdir -p /www/data

echo "$DATA" > "$TMP_FILE" || exit 1
cp "$TMP_FILE" "$DATA_FILE" || exit 1
rm -f "$TMP_FILE"
sync

[ -s "$DATA_FILE" ] || {
    echo "[Bandix] ERROR: users.json empty" >> /tmp/bandix.log
    exit 1
}

OLD_FP_FILE="/tmp/bandix_users.fp"

NEW_FP="$(generate_users_fingerprint "$DATA_FILE")"
echo "[Bandix] FP=$NEW_FP" >> /tmp/bandix.log
OLD_FP="$(cat "$OLD_FP_FILE" 2>/dev/null)"

if add_dhcp_leases; then
    echo "$NEW_FP" > "$OLD_FP_FILE"

    # 🔄 update cron ONLY when users changed
    REFRESH=$(jsonfilter -i "$DATA_FILE" -e '@._refresh' 2>/dev/null)
    [ -z "$REFRESH" ] && REFRESH=2

    sed -i '/bandix-cron/d' /etc/crontabs/root
    echo "*/$REFRESH * * * * /usr/bin/bandix-flush && /usr/bin/bandix-quota # bandix-cron" >> /etc/crontabs/root
    /etc/init.d/cron restart

else
    echo "[Bandix] USERS unchanged -> skip DHCP rebuild" >> /tmp/bandix.log
fi

# ✅ APPLY QUOTA IMMEDIATELY
/usr/bin/bandix-quota force >> /tmp/bandix.log 2>&1 || \
echo "[Bandix] quota failed" >> /tmp/bandix.log

respond '{"status":"ok"}'
exit 0
