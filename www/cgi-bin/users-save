#!/bin/busybox sh

TMP_BASE="/tmp/bandixpage"
LOG_DIR="$TMP_BASE"

mkdir -p "$TMP_BASE"

ln -sf /tmp/bandixpage/devices.txt /www/devices.txt

LOG="$LOG_DIR/bandixusers.log"

echo "RUN $(date)" > "$LOG"

# 🔒 ATOMIC LOCK
LOCK="$TMP_BASE/bandix-users.lock"

# remove stale lock
if [ -d "$LOCK" ]; then
    AGE=$(( $(date +%s) - $(stat -c %Y "$LOCK" 2>/dev/null || echo 0) ))
    if [ "$AGE" -gt 30 ]; then
        echo "[Bandix] REMOVE STALE LOCK" >> "$LOG"
        rm -rf "$LOCK"
    fi
fi

if ! mkdir "$LOCK" 2>/dev/null; then
    echo "[Bandix] LOCKED" >> "$LOG"
    respond '{"status":"error","message":"locked"}'
    exit 0
fi

cleanup() {
    rm -rf "$LOCK"
}
trap cleanup EXIT INT TERM

DATA_FILE="/www/data/users.json"
PAY_FILE="/www/data/users-pay.json"

# 🔐 load password from users-pay.json
if [ -f "$PAY_FILE" ]; then
    PASSWORD=$(jsonfilter -i "$PAY_FILE" -e '@.password')
else
    PASSWORD=""
fi

TMP_FILE="$TMP_BASE/users.json.tmp"
MAX_SIZE=65536

read_post_data() {
    if [ -n "$CONTENT_LENGTH" ]; then
        read -r -n "$CONTENT_LENGTH" POST_DATA
    else
        POST_DATA=$(cat)
    fi
}

respond() {
    printf "Content-Type: application/json\r\n"
    printf "\r\n"
    printf "%s" "$1"
}

add_dhcp_leases() {

    CACHE="$TMP_BASE/bandix.cache"

    # --- NETWORK ---
    NETWORK=$(grep '^META|network|' "$CACHE" | cut -d'|' -f3)
    [ -z "$NETWORK" ] && NETWORK="192.168.2"

    case "$NETWORK" in
        [0-9]*.[0-9]*.[0-9]*) ;;
        *) NETWORK="192.168.2" ;;
    esac

    # --- REMOVE OLD BANDIX HOSTS ---
    INDEX=0
    while true; do
        TAG=$(uci get dhcp.@host[$INDEX].tag 2>/dev/null)

        [ -z "$TAG" ] && break

        if [ "$TAG" = "bandix" ]; then
            uci delete dhcp.@host[$INDEX]
            continue
        fi

        INDEX=$((INDEX + 1))
    done

    # --- BUILD NEW CONFIG (BATCH) ---
    TMP_UCI="$TMP_BASE/bandix.uci"
    : > "$TMP_UCI"

    USER_INDEX=0
    CURRENT_USER=""
    MAC_INDEX=0

    while IFS='|' read -r USER MAC QUOTA; do

        [ "$USER" = "META" ] && continue

        if [ "$USER" != "$CURRENT_USER" ]; then
            CURRENT_USER="$USER"
            MAC_INDEX=0
            BASE=$((20 + USER_INDEX * 10))
            USER_INDEX=$((USER_INDEX + 1))
        fi

        MAC_UP=$(echo "$MAC" | tr '[:lower:]' '[:upper:]')

        IP="$NETWORK.$((BASE + MAC_INDEX))"
        NAME="${USER}-$((MAC_INDEX + 1))"

        {
            echo "add dhcp host"
            echo "set dhcp.@host[-1].name=$NAME"
            echo "set dhcp.@host[-1].mac=$MAC_UP"
            echo "set dhcp.@host[-1].ip=$IP"
            echo "set dhcp.@host[-1].leasetime=infinite"
            echo "set dhcp.@host[-1].tag=bandix"
        } >> "$TMP_UCI"

        MAC_INDEX=$((MAC_INDEX + 1))

    done < "$CACHE"

    # --- APPLY IN ONE GO ---
    if ! uci batch < "$TMP_UCI" >/dev/null 2>&1; then
        echo "[Bandix] uci batch failed" >> "$LOG"
    fi

    if ! uci commit dhcp >/dev/null 2>&1; then
        echo "[Bandix] uci commit failed" >> "$LOG"
    fi

    # --- CLEANUP NETWORK STATE ---
    : > /tmp/dhcp.leases 2>/dev/null
    ip neigh flush all >/dev/null 2>&1

    (
        ubus call service reload '{"name":"dnsmasq"}' >/dev/null 2>&1 \
            || /etc/init.d/dnsmasq restart >/dev/null 2>&1
    ) &

    return 0
}

generate_dhcp_fp() {

    CACHE="$TMP_BASE/bandix.cache"

    NETWORK=$(grep '^META|network|' "$CACHE" | cut -d'|' -f3)
    [ -z "$NETWORK" ] && NETWORK="192.168.2"

    case "$NETWORK" in
        [0-9]*.[0-9]*.[0-9]*) ;;
        *) NETWORK="192.168.2" ;;
    esac

    USER_INDEX=0
    CURRENT_USER=""
    MAC_INDEX=0

    while IFS='|' read -r USER MAC QUOTA; do

        # skip META lines
        [ "$USER" = "META" ] && continue

        # new user → reset MAC index
        if [ "$USER" != "$CURRENT_USER" ]; then
            CURRENT_USER="$USER"
            MAC_INDEX=0
            BASE=$((20 + USER_INDEX * 10))
            USER_INDEX=$((USER_INDEX + 1))
        fi

        MAC_UP=$(echo "$MAC" | tr '[:lower:]' '[:upper:]')
        IP="$NETWORK.$((BASE + MAC_INDEX))"
        NAME="${USER}-$((MAC_INDEX + 1))"

        echo "$NAME|$MAC_UP|$IP"

        MAC_INDEX=$((MAC_INDEX + 1))

    done < "$CACHE" | sort | md5sum | cut -d' ' -f1
}

generate_quota_fp() {

    CACHE="$TMP_BASE/bandix.cache"

    MULTIPLIER=$(grep '^META|multiplier|' "$CACHE" | cut -d'|' -f3)
    [ -z "$MULTIPLIER" ] && MULTIPLIER=1

    ADMIN=$(grep '^META|admin|' "$CACHE" | cut -d'|' -f3)
    ZONE=$(grep '^META|zone|' "$CACHE" | cut -d'|' -f3)

    {
        echo "MULTIPLIER=$MULTIPLIER"
        echo "ADMIN=$ADMIN"
        echo "ZONE=$ZONE"

        while IFS='|' read -r USER MAC QUOTA; do

            # skip META lines
            [ "$USER" = "META" ] && continue

            MAC_UP=$(echo "$MAC" | tr '[:lower:]' '[:upper:]')
            [ -z "$QUOTA" ] && QUOTA=0

            echo "$USER|$MAC_UP|$QUOTA"

        done < "$CACHE"

    } | sort | md5sum | cut -d' ' -f1
}

update_cron() {

    CACHE="$TMP_BASE/bandix.cache"

    REFRESH=$(grep '^META|refresh|' "$CACHE" | cut -d'|' -f3)

    [ -z "$REFRESH" ] && REFRESH=2
    [ "$REFRESH" -lt 1 ] && REFRESH=1
    [ "$REFRESH" -gt 60 ] && REFRESH=60

    CRON_FILE="/etc/crontabs/root"

    # 🔥 REMOVE ALL existing bandix-quota entries
    grep -v 'bandix-quota' "$CRON_FILE" > "$CRON_FILE.tmp"
    mv "$CRON_FILE.tmp" "$CRON_FILE"

    # 🔥 ADD SINGLE clean entry
    echo "*/$REFRESH * * * * /usr/bin/bandix-quota" >> "$CRON_FILE"

    # reload cron
    /etc/init.d/cron restart
}

build_cache() {

    CACHE="$TMP_BASE/bandix.cache"
    : > "$CACHE"

    # --- META ---
    NETWORK=$(jsonfilter -i "$DATA_FILE" -e '@._network' 2>/dev/null)
    REFRESH=$(jsonfilter -i "$DATA_FILE" -e '@._refresh' 2>/dev/null)
    MULTIPLIER=$(jsonfilter -i "$DATA_FILE" -e '@._multiplier' 2>/dev/null)
    ADMIN=$(jsonfilter -i "$DATA_FILE" -e '@._admin' 2>/dev/null)
    ZONE=$(jsonfilter -i "$DATA_FILE" -e '@._zone' 2>/dev/null)

    echo "META|network|$NETWORK" >> "$CACHE"
    echo "META|refresh|$REFRESH" >> "$CACHE"
    echo "META|multiplier|$MULTIPLIER" >> "$CACHE"
    echo "META|admin|$ADMIN" >> "$CACHE"
    echo "META|zone|$ZONE" >> "$CACHE"

    # --- USERS ---
    USERS=$(jsonfilter -i "$DATA_FILE" -e '@' | \
        tr '{},' '\n' | grep ':' | cut -d':' -f1 | tr -d '" ')

    for USER in $USERS; do

        # skip system keys
        echo "$USER" | grep -q "^_" && continue
        echo "$USER" | grep -Eq '^[0-9]+$' && continue

        # quota
        QUOTA=$(jsonfilter -i "$DATA_FILE" -e "@.$USER.quota" 2>/dev/null)
        [ -z "$QUOTA" ] && QUOTA=0

        INDEX=0
        while true; do
            MAC=$(jsonfilter -i "$DATA_FILE" -e "@.$USER.macs[$INDEX]" 2>/dev/null)
            [ -z "$MAC" ] && break

            echo "$USER|$MAC|$QUOTA" >> "$CACHE"

            INDEX=$((INDEX + 1))
        done
    done
}
# -------------------------

read_post_data

# 🧹 CLEANUP ACTION (before normal validation flow)
ACTION=$(echo "$POST_DATA" | jsonfilter -e '@.action')

if [ "$ACTION" = "cleanup" ]; then

    PASS=$(echo "$POST_DATA" | jsonfilter -e '@.password')

    [ "$PASS" = "$PASSWORD" ] || {
        respond '{"status":"error","message":"unauthorized"}'
        exit 1
    }

    echo "[Bandix] CLEANUP TRIGGERED" >> "$LOG"

    rm -rf /usr/share/bandix/* 2>> "$LOG"

    /etc/init.d/bandix restart >> "$LOG" 2>&1 || {
        echo "[Bandix] restart failed" >> "$LOG"
        respond '{"status":"error","message":"restart_failed"}'
        exit 1
    }

    respond '{"status":"ok"}'
    exit 0
fi

[ -n "$POST_DATA" ] || {
    respond '{"status":"error","message":"empty"}'
    exit 1
}

SIZE=$(printf "%s" "$POST_DATA" | wc -c)
[ "$SIZE" -le "$MAX_SIZE" ] || {
    respond '{"status":"error","message":"too_large"}'
    exit 1
}

PASS=$(echo "$POST_DATA" | jsonfilter -e '@.password')

[ "$PASS" = "$PASSWORD" ] || {
    respond '{"status":"error","message":"unauthorized"}'
    exit 1
}

DATA=$(echo "$POST_DATA" | jsonfilter -e '@.data')

[ -n "$DATA" ] || {
    respond '{"status":"error","message":"no_data"}'
    exit 1
}

echo "$DATA" | jsonfilter -e '@' >/dev/null 2>&1 || {
    respond '{"status":"error","message":"invalid_json"}'
    exit 1
}

mkdir -p /www/data

echo "$DATA" > "$TMP_FILE" || exit 1
cp "$TMP_FILE" "$DATA_FILE" || exit 1
rm -f "$TMP_FILE"

build_cache
cat "$TMP_BASE/bandix.cache" >> "$LOG"


[ -s "$DATA_FILE" ] || {
    echo "[Bandix] ERROR: users.json empty" >> "$LOG"
    exit 1
}

DHCP_FP_FILE="$TMP_BASE/bandix_dhcp.fp"
REFRESH_FP_FILE="$TMP_BASE/bandix_refresh.fp"
QUOTA_FP_FILE="$TMP_BASE/bandix_quota.fp"

NEW_QUOTA_FP="$(generate_quota_fp)"
OLD_QUOTA_FP="$(cat "$QUOTA_FP_FILE" 2>/dev/null)"

NEW_DHCP_FP="$(generate_dhcp_fp)"
OLD_DHCP_FP="$(cat "$DHCP_FP_FILE" 2>/dev/null)"

NEW_REFRESH=$(grep '^META|refresh|' "$TMP_BASE/bandix.cache" | cut -d'|' -f3)
echo "$NEW_REFRESH" | grep -Eq '^[0-9]+$' || NEW_REFRESH=2
OLD_REFRESH="$(cat "$REFRESH_FP_FILE" 2>/dev/null)"

echo "[Bandix] DHCP_FP=$NEW_DHCP_FP" >> "$LOG"


# ---- DHCP changes ----
if [ "$NEW_DHCP_FP" != "$OLD_DHCP_FP" ]; then

    echo "[Bandix] DHCP changed -> rebuilding" >> "$LOG"

    if add_dhcp_leases; then
        echo "$NEW_DHCP_FP" > "$DHCP_FP_FILE"

        # ✅ RUN ONLY WHEN CHANGED (same logic)
        /usr/bin/generate-hosts.sh >> "$LOG" 2>&1 || true

    else
        echo "[Bandix] DHCP rebuild failed" >> "$LOG"
        respond '{"status":"error","message":"dhcp_failed"}'
        exit 0
    fi

else
    echo "[Bandix] DHCP unchanged" >> "$LOG"
fi


# ---- REFRESH changes ----
if [ "$NEW_REFRESH" != "$OLD_REFRESH" ]; then

    echo "[Bandix] REFRESH changed -> updating cron" >> "$LOG"

    update_cron
    echo "$NEW_REFRESH" > "$REFRESH_FP_FILE"

else
    echo "[Bandix] REFRESH unchanged" >> "$LOG"
fi

# ---- QUOTA changes ----
if [ "$NEW_QUOTA_FP" != "$OLD_QUOTA_FP" ]; then

    echo "[Bandix] QUOTA changed -> applying" >> "$LOG"

    /usr/bin/bandix-quota force >> "$LOG" 2>&1 || true

    echo "$NEW_QUOTA_FP" > "$QUOTA_FP_FILE"

else
    echo "[Bandix] QUOTA unchanged" >> "$LOG"
fi

respond '{"status":"ok"}'
exit 0
