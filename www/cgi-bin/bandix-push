#!/bin/busybox sh

BUFFER="/tmp/bandix-buffer.json"

read_post_data() {
    if [ -n "$CONTENT_LENGTH" ]; then
        read -r -n "$CONTENT_LENGTH" POST_DATA
    else
        POST_DATA=$(cat)
    fi
}

respond() {
    echo "Content-Type: application/json"
    echo ""
    echo "$1"
}

read_post_data

# Save to RAM only
echo "$POST_DATA" > "$BUFFER"

respond '{"status":"buffered"}'
exit 0


