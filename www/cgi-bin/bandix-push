#!/bin/busybox sh

TMP_BASE="/tmp/bandixpage"
mkdir -p "$TMP_BASE"

BUFFER="$TMP_BASE/bandix-buffer.json"
TMP="$TMP_BASE/bandix-buffer.json.tmp"
LOCK="$TMP_BASE/bandix.lock"

LAST_WRITE="$TMP_BASE/last_write"
INTERVAL=30  # seconds

read_post_data() {
    POST_DATA=$(cat)
}

respond() {
    echo "Content-Type: application/json"
    echo ""
    echo "$1"
}

read_post_data

[ -z "$POST_DATA" ] && respond '{"status":"empty"}' && exit 0

# 🚀 THROTTLE BEFORE LOCK (big win)
NOW=$(date +%s)
LAST=$(cat "$LAST_WRITE" 2>/dev/null || echo 0)

if [ $((NOW - LAST)) -lt $INTERVAL ]; then
    respond '{"status":"throttled"}'
    exit 0
fi

# 🔒 stale lock cleanup
if [ -d "$LOCK" ]; then
    AGE=$(( $(date +%s) - $(stat -c %Y "$LOCK" 2>/dev/null || echo 0) ))
    [ "$AGE" -gt 30 ] && rm -rf "$LOCK"
fi

if ! mkdir "$LOCK" 2>/dev/null; then
    respond '{"status":"busy"}'
    exit 0
fi

trap 'rm -rf "$LOCK"' EXIT INT TERM

# write + flush (since we already passed throttle)
echo "$POST_DATA" > "$TMP"
mv "$TMP" "$BUFFER"
echo "$NOW" > "$LAST_WRITE"

respond '{"status":"flushed"}'
exit 0
