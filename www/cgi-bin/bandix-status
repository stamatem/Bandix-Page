#!/bin/busybox sh

echo "Content-Type: application/json"
echo ""

FILE="/tmp/bandixquota.log"

if [ ! -f "$FILE" ]; then
    echo '{"status":"missing"}'
    exit 0
fi

# get last modified time (epoch)
TS=$(date -r "$FILE" +%s 2>/dev/null)

if [ -z "$TS" ]; then
    echo '{"status":"error"}'
    exit 0
fi

echo "{\"status\":\"ok\",\"ts\":$TS}"


