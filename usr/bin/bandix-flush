#!/bin/busybox sh

umask 002

IN="/tmp/bandix-buffer.json"
OUT="/www/data/bandix-public.json"
TMP="/tmp/bandix-public.json"

[ ! -s "$IN" ] && exit 0

# copy instead of mv (safer across fs)
cp "$IN" "$TMP" || exit 1

# set correct permissions BEFORE move
chown root:nogroup "$TMP"
chmod 664 "$TMP"

# overwrite destination safely
cp "$TMP" "$OUT" || exit 1

# enforce correct ownership on final file
chown root:nogroup "$OUT"
chmod 664 "$OUT"

# cleanup
rm -f "$TMP"


